# Harness Maintainer Makefile
# Used by harness project maintainers to build and publish container images
#
# Usage:
#   make -f Makefile.publish build-all       # Build all provider images
#   make -f Makefile.publish push-all        # Push all provider images
#   make -f Makefile.publish publish-all     # Build and push all
#   make -f Makefile.publish build-claude    # Build a specific provider
#   make -f Makefile.publish VERSION=v1.2.3 publish-all  # Tag with version

# ══════════════════════════════════════════════════════════════════════════════
# Configuration
# ══════════════════════════════════════════════════════════════════════════════

# Container runtime (auto-detect)
CONTAINER_RUNTIME ?= $(shell command -v podman 2>/dev/null || command -v docker 2>/dev/null || echo "podman")

# Registry and org
REGISTRY ?= quay.io
ORG ?= aap
PROJECT ?= harness

# Version (defaults to git describe, fallback to latest)
VERSION ?= $(shell git describe --tags --always --dirty 2>/dev/null || echo "latest")

# Image naming
IMAGE_PREFIX := $(REGISTRY)/$(ORG)/$(PROJECT)

# Providers
PROVIDERS := claude openai vertex local

# Build context
CONTEXT_DIR := modules/harness/containers

# Build args
BUILD_DATE := $(shell date -u +"%Y-%m-%dT%H:%M:%SZ")
VCS_REF := $(shell git rev-parse --short HEAD 2>/dev/null || echo "unknown")

# ══════════════════════════════════════════════════════════════════════════════
# Phony targets
# ══════════════════════════════════════════════════════════════════════════════

.PHONY: help
.PHONY: build-all build-claude build-openai build-vertex build-local
.PHONY: push-all push-claude push-openai push-vertex push-local
.PHONY: publish-all publish-claude publish-openai publish-vertex publish-local
.PHONY: login test-images clean

# ══════════════════════════════════════════════════════════════════════════════
# Help
# ══════════════════════════════════════════════════════════════════════════════

help: ## Show this help
	@echo "Harness Container Image Publisher"
	@echo ""
	@echo "Configuration:"
	@echo "  CONTAINER_RUNTIME = $(CONTAINER_RUNTIME)"
	@echo "  REGISTRY          = $(REGISTRY)"
	@echo "  ORG               = $(ORG)"
	@echo "  VERSION           = $(VERSION)"
	@echo ""
	@echo "Images:"
	@$(foreach provider,$(PROVIDERS),echo "  $(IMAGE_PREFIX)-$(provider):$(VERSION)";)
	@echo ""
	@echo "Targets:"
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "  %-20s %s\n", $$1, $$2}'

# ══════════════════════════════════════════════════════════════════════════════
# Authentication
# ══════════════════════════════════════════════════════════════════════════════

login: ## Login to container registry (supports quay.io, ghcr.io, or any registry)
	@echo "Logging in to $(REGISTRY)..."
	@if [ -n "$$REGISTRY_PASSWORD" ]; then \
		echo "$$REGISTRY_PASSWORD" | $(CONTAINER_RUNTIME) login $(REGISTRY) -u $${REGISTRY_USER:-$$USER} --password-stdin; \
	elif [ -n "$$GITHUB_TOKEN" ] && echo "$(REGISTRY)" | grep -q "ghcr.io"; then \
		echo "$$GITHUB_TOKEN" | $(CONTAINER_RUNTIME) login $(REGISTRY) -u $${GITHUB_USER:-$$USER} --password-stdin; \
	elif command -v gh >/dev/null 2>&1 && echo "$(REGISTRY)" | grep -q "ghcr.io"; then \
		gh auth token | $(CONTAINER_RUNTIME) login $(REGISTRY) -u $$(gh api user --jq .login) --password-stdin; \
	else \
		$(CONTAINER_RUNTIME) login $(REGISTRY); \
	fi

# ══════════════════════════════════════════════════════════════════════════════
# Build targets
# ══════════════════════════════════════════════════════════════════════════════

build-all: build-claude build-openai build-vertex build-local ## Build all provider images

build-claude: ## Build Claude (Anthropic) provider image
	@echo "Building harness-claude:$(VERSION)..."
	@$(CONTAINER_RUNTIME) build \
		--file $(CONTEXT_DIR)/Containerfile.claude \
		--tag $(IMAGE_PREFIX)-claude:$(VERSION) \
		--tag $(IMAGE_PREFIX)-claude:latest \
		--label "org.opencontainers.image.created=$(BUILD_DATE)" \
		--label "org.opencontainers.image.version=$(VERSION)" \
		--label "org.opencontainers.image.revision=$(VCS_REF)" \
		--label "org.opencontainers.image.source=https://github.com/$(ORG)/$(PROJECT)" \
		$(CONTEXT_DIR)

build-openai: ## Build OpenAI provider image
	@echo "Building harness-openai:$(VERSION)..."
	@$(CONTAINER_RUNTIME) build \
		--file $(CONTEXT_DIR)/Containerfile.openai \
		--tag $(IMAGE_PREFIX)-openai:$(VERSION) \
		--tag $(IMAGE_PREFIX)-openai:latest \
		--label "org.opencontainers.image.created=$(BUILD_DATE)" \
		--label "org.opencontainers.image.version=$(VERSION)" \
		--label "org.opencontainers.image.revision=$(VCS_REF)" \
		--label "org.opencontainers.image.source=https://github.com/$(ORG)/$(PROJECT)" \
		$(CONTEXT_DIR)

build-vertex: ## Build Google Vertex AI provider image
	@echo "Building harness-vertex:$(VERSION)..."
	@$(CONTAINER_RUNTIME) build \
		--file $(CONTEXT_DIR)/Containerfile.vertex \
		--tag $(IMAGE_PREFIX)-vertex:$(VERSION) \
		--tag $(IMAGE_PREFIX)-vertex:latest \
		--label "org.opencontainers.image.created=$(BUILD_DATE)" \
		--label "org.opencontainers.image.version=$(VERSION)" \
		--label "org.opencontainers.image.revision=$(VCS_REF)" \
		--label "org.opencontainers.image.source=https://github.com/$(ORG)/$(PROJECT)" \
		$(CONTEXT_DIR)

build-local: ## Build local (Ollama) provider image
	@echo "Building harness-local:$(VERSION)..."
	@$(CONTAINER_RUNTIME) build \
		--file $(CONTEXT_DIR)/Containerfile.local \
		--tag $(IMAGE_PREFIX)-local:$(VERSION) \
		--tag $(IMAGE_PREFIX)-local:latest \
		--label "org.opencontainers.image.created=$(BUILD_DATE)" \
		--label "org.opencontainers.image.version=$(VERSION)" \
		--label "org.opencontainers.image.revision=$(VCS_REF)" \
		--label "org.opencontainers.image.source=https://github.com/$(ORG)/$(PROJECT)" \
		$(CONTEXT_DIR)

# ══════════════════════════════════════════════════════════════════════════════
# Push targets
# ══════════════════════════════════════════════════════════════════════════════

push-all: push-claude push-openai push-vertex push-local ## Push all provider images to registry

push-claude: ## Push Claude provider image
	@echo "Pushing harness-claude:$(VERSION)..."
	@$(CONTAINER_RUNTIME) push $(IMAGE_PREFIX)-claude:$(VERSION)
	@if [ "$(VERSION)" != "latest" ]; then \
		$(CONTAINER_RUNTIME) push $(IMAGE_PREFIX)-claude:latest; \
	fi

push-openai: ## Push OpenAI provider image
	@echo "Pushing harness-openai:$(VERSION)..."
	@$(CONTAINER_RUNTIME) push $(IMAGE_PREFIX)-openai:$(VERSION)
	@if [ "$(VERSION)" != "latest" ]; then \
		$(CONTAINER_RUNTIME) push $(IMAGE_PREFIX)-openai:latest; \
	fi

push-vertex: ## Push Vertex AI provider image
	@echo "Pushing harness-vertex:$(VERSION)..."
	@$(CONTAINER_RUNTIME) push $(IMAGE_PREFIX)-vertex:$(VERSION)
	@if [ "$(VERSION)" != "latest" ]; then \
		$(CONTAINER_RUNTIME) push $(IMAGE_PREFIX)-vertex:latest; \
	fi

push-local: ## Push local (Ollama) provider image
	@echo "Pushing harness-local:$(VERSION)..."
	@$(CONTAINER_RUNTIME) push $(IMAGE_PREFIX)-local:$(VERSION)
	@if [ "$(VERSION)" != "latest" ]; then \
		$(CONTAINER_RUNTIME) push $(IMAGE_PREFIX)-local:latest; \
	fi

# ══════════════════════════════════════════════════════════════════════════════
# Publish targets (build + push)
# ══════════════════════════════════════════════════════════════════════════════

publish-all: build-all push-all ## Build and push all provider images

publish-claude: build-claude push-claude ## Build and push Claude provider image

publish-openai: build-openai push-openai ## Build and push OpenAI provider image

publish-vertex: build-vertex push-vertex ## Build and push Vertex AI provider image

publish-local: build-local push-local ## Build and push local provider image

# ══════════════════════════════════════════════════════════════════════════════
# Test targets
# ══════════════════════════════════════════════════════════════════════════════

test-images: ## Test all built images (smoke tests — pass GCP_PROJECT_ID for claude)
	@echo "Testing harness-claude..."
	@$(CONTAINER_RUNTIME) run --rm \
		-e GCP_PROJECT_ID=$(GCP_PROJECT_ID) \
		-e GCP_REGION=$(or $(GCP_REGION),us-east5) \
		-e GCP_QUOTA_PROJECT=$(or $(GCP_QUOTA_PROJECT),$(GCP_PROJECT_ID)) \
		-v $(HOME)/.config/gcloud/application_default_credentials.json:/tmp/adc.json:z \
		--entrypoint /bin/bash \
		$(IMAGE_PREFIX)-claude:$(VERSION) \
		-c 'cp /tmp/adc.json /home/harness/.config/gcloud/application_default_credentials.json 2>/dev/null && \
		    gcloud config set project $$GCP_PROJECT_ID --quiet 2>/dev/null && \
		    python3 -c "from anthropic import AnthropicVertex; print(\"  anthropic[vertex]: OK\")" && \
		    echo "  gcloud auth: OK"'
	@echo "Testing harness-openai..."
	@$(CONTAINER_RUNTIME) run --rm $(IMAGE_PREFIX)-openai:$(VERSION) --version || echo "  (no --version flag)"
	@echo "Testing harness-vertex..."
	@$(CONTAINER_RUNTIME) run --rm $(IMAGE_PREFIX)-vertex:$(VERSION) --version || echo "  (no --version flag)"
	@echo "Testing harness-local..."
	@$(CONTAINER_RUNTIME) run --rm $(IMAGE_PREFIX)-local:$(VERSION) --version || echo "  (no --version flag)"
	@echo "All images tested successfully."

# ══════════════════════════════════════════════════════════════════════════════
# Cleanup
# ══════════════════════════════════════════════════════════════════════════════

clean: ## Remove locally built images
	@echo "Removing local harness images..."
	@$(CONTAINER_RUNTIME) rmi $(IMAGE_PREFIX)-claude:$(VERSION) 2>/dev/null || true
	@$(CONTAINER_RUNTIME) rmi $(IMAGE_PREFIX)-claude:latest 2>/dev/null || true
	@$(CONTAINER_RUNTIME) rmi $(IMAGE_PREFIX)-openai:$(VERSION) 2>/dev/null || true
	@$(CONTAINER_RUNTIME) rmi $(IMAGE_PREFIX)-openai:latest 2>/dev/null || true
	@$(CONTAINER_RUNTIME) rmi $(IMAGE_PREFIX)-vertex:$(VERSION) 2>/dev/null || true
	@$(CONTAINER_RUNTIME) rmi $(IMAGE_PREFIX)-vertex:latest 2>/dev/null || true
	@$(CONTAINER_RUNTIME) rmi $(IMAGE_PREFIX)-local:$(VERSION) 2>/dev/null || true
	@$(CONTAINER_RUNTIME) rmi $(IMAGE_PREFIX)-local:latest 2>/dev/null || true
	@echo "Cleanup complete."
