# Harness Agent Container - Local (Ollama)
# This container runs AI agents with local Ollama models

FROM ollama/ollama:latest

LABEL maintainer="Platform Team"
LABEL description="Harness AI agent container for local Ollama models"

# Install additional dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    jq \
    python3 \
    python3-pip \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip3 install --no-cache-dir --break-system-packages \
    tree-sitter>=0.20.0 \
    pyyaml \
    requests

# Create non-root user
RUN useradd -m -s /bin/bash harness
WORKDIR /workspace

# Create workspace directories
RUN mkdir -p /workspace/.harness

# Default model to pull
ENV OLLAMA_MODEL=llama3.2

# Default entrypoint
COPY --chown=root:root entrypoint-local.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["assist"]
