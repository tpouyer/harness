{
  "version": "1.0",
  "description": "Harness agent container configuration for paude",
  "base": "python:3.11-slim",
  "packages": [
    "git",
    "jq",
    "curl",
    "tree-sitter-cli"
  ],
  "setup": "pip install anthropic openai tree-sitter pyyaml",
  "venv": "auto",
  "security": {
    "network_filter": true,
    "allowed_domains": [
      "api.anthropic.com",
      "api.openai.com",
      "*.googleapis.com",
      "*.atlassian.net"
    ],
    "blocked_ports": [22, 25, 465, 587],
    "read_only_root": true,
    "no_new_privileges": true
  },
  "resources": {
    "memory_limit": "2Gi",
    "cpu_limit": "2",
    "timeout_seconds": 300
  },
  "volumes": {
    "/workspace": "readwrite",
    "/workspace/.harness": "readwrite"
  },
  "environment": {
    "PYTHONUNBUFFERED": "1",
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
