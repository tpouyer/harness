# Harness AAP-Dev Integration
# Targets for installing and running the Ansible Automation Platform development environment
# https://github.com/ansible/aap-dev

SHELL := /bin/bash

# AAP-Dev Configuration (defaults from defaults.mk, can override here)
export AAP_DEV_REPO ?= https://github.com/ansible/aap-dev.git
export AAP_DEV_DIR ?= $(HARNESS_STATE_DIR)/aap-dev
export AAP_DEV_BRANCH ?= main
export AAP_VERSION ?= 2.6-next
export AAP_CONTAINER_RUNTIME ?= podman

# Skip deployment check if explicitly disabled
export AAP_SKIP_DEPLOY_CHECK ?= false

export AAP_DEFAULT_MAKE_TARGET ?= aap
export AAP_INSTALL_LICENSE ?= false

.PHONY: harness/aap-dev/help
## Show AAP-Dev help
harness/aap-dev/help:
	@echo "Harness AAP-Dev Integration"
	@echo "============================"
	@echo ""
	@echo "Ansible Automation Platform development environment management"
	@echo "Repository: https://github.com/ansible/aap-dev"
	@echo ""
	@echo "Setup:"
	@echo "  harness/aap-dev/install       Clone and setup aap-dev repository"
	@echo "  harness/aap-dev/preflight     Check all prerequisites"
	@echo "  harness/aap-dev/registry-login Login to required container registries"
	@echo ""
	@echo "Running:"
	@echo "  harness/aap-dev/start         Start AAP development environment"
	@echo "  harness/aap-dev/stop          Stop AAP (Ctrl+C skaffold and clean)"
	@echo "  harness/aap-dev/status        Show AAP pod status"
	@echo "  harness/aap-dev/logs          Tail AAP logs"
	@echo "  harness/aap-dev/admin-password Get admin password"
	@echo ""
	@echo "Management:"
	@echo "  harness/aap-dev/apply-license Apply AAP license"
	@echo "  harness/aap-dev/backup        Backup AAP PostgreSQL database"
	@echo "  harness/aap-dev/restore       Restore AAP database from backup"
	@echo "  harness/aap-dev/versions      List available AAP versions"
	@echo ""
	@echo "Testing (auto-deploys AAP if not running):"
	@echo "  harness/aap-dev/test          Run all ATF tests"
	@echo "  harness/aap-dev/test/controller Run controller tests"
	@echo "  harness/aap-dev/test/eda      Run EDA tests"
	@echo "  harness/aap-dev/test/hub      Run hub tests"
	@echo "  harness/aap-dev/test/init     Initialize test suite"
	@echo ""
	@echo "Source Configuration:"
	@echo "  harness/aap-dev/configure-sources     Interactive source setup"
	@echo "  harness/aap-dev/configure-sources-auto Non-interactive (ANSWERS_FILE=path)"
	@echo "  harness/aap-dev/show-sources           Show configured sources"
	@echo "  harness/aap-dev/reset-sources           Reset to nightly defaults"
	@echo ""
	@echo "Data Seeding:"
	@echo "  harness/aap-dev/seed          Seed data using default playbook"
	@echo "  harness/aap-dev/seed-custom   Seed with custom playbook (SEED_PLAYBOOK=path)"
	@echo ""
	@echo "Observability:"
	@echo "  harness/aap-dev/metrics       Show CPU/memory per pod"
	@echo "  harness/aap-dev/metrics-node  Show CPU/memory per node"
	@echo "  harness/aap-dev/observability Install Prometheus + Grafana stack"
	@echo ""
	@echo "Content Regeneration:"
	@echo "  harness/aap-dev/regenerate-containerfiles  Update Containerfiles from upstream"
	@echo "  harness/aap-dev/regenerate-k8s-manifests   Extract K8s manifests from live AAP"
	@echo ""
	@echo "Deployment:"
	@echo "  harness/aap-dev/deploy        Deploy AAP (non-blocking)"
	@echo "  harness/aap-dev/wait-up       Wait for AAP API to be available"
	@echo "  harness/aap-dev/ensure-running Ensure AAP is deployed and ready"
	@echo ""
	@echo "Cleanup:"
	@echo "  harness/aap-dev/clean         Remove kind cluster and kubeconfig"
	@echo "  harness/aap-dev/clean-all     Full removal (really-clean)"
	@echo ""
	@echo "Configuration:"
	@echo "  AAP_DEV_DIR      Installation directory (default: .harness/aap-dev)"
	@echo "                   Override in .harness.local.env to use existing clone"
	@echo "  AAP_VERSION      AAP version to run (default: 2.6-next)"
	@echo "  AAP_DEV_BRANCH   Git branch to use (default: main)"
	@echo ""
	@echo "Examples:"
	@echo "  make harness/aap-dev/install"
	@echo "  make harness/aap-dev/start"
	@echo "  make harness/aap-dev/start AAP_VERSION=2.5-next"

.PHONY: harness/aap-dev/install
## Clone and setup the aap-dev repository
harness/aap-dev/install: harness/aap-dev/preflight
	@echo "Installing AAP-Dev..."
	@echo ""
	@if [ -d "$(AAP_DEV_DIR)" ]; then \
		echo "AAP-Dev directory already exists at $(AAP_DEV_DIR)"; \
		echo "Updating repository..."; \
		cd "$(AAP_DEV_DIR)" && git pull origin $(AAP_DEV_BRANCH); \
	else \
		echo "Cloning aap-dev to $(AAP_DEV_DIR)..."; \
		git clone --branch $(AAP_DEV_BRANCH) $(AAP_DEV_REPO) "$(AAP_DEV_DIR)"; \
	fi
	@echo ""
	@echo "AAP-Dev installed successfully!"
	@echo ""
	@echo "Next steps:"
	@echo "  1. Ensure you're logged into container registries:"
	@echo "     make harness/aap-dev/registry-login"
	@echo "  2. Start AAP:"
	@echo "     make harness/aap-dev/start"

.PHONY: harness/aap-dev/preflight
## Check prerequisites for aap-dev
harness/aap-dev/preflight:
	@echo "AAP-Dev Preflight Check"
	@echo "======================="
	@echo ""
	@ERRORS=0; \
	echo "Checking required tools..."; \
	echo ""; \
	if command -v podman >/dev/null 2>&1; then \
		echo "✓ podman: $$(podman --version)"; \
	else \
		echo "✗ podman: NOT INSTALLED"; \
		echo "  Install: make harness/deps/podman"; \
		ERRORS=$$((ERRORS + 1)); \
	fi; \
	if command -v make >/dev/null 2>&1; then \
		echo "✓ make: $$(make --version | head -1)"; \
	else \
		echo "✗ make: NOT INSTALLED"; \
		ERRORS=$$((ERRORS + 1)); \
	fi; \
	if command -v git >/dev/null 2>&1; then \
		echo "✓ git: $$(git --version)"; \
	else \
		echo "✗ git: NOT INSTALLED"; \
		ERRORS=$$((ERRORS + 1)); \
	fi; \
	echo ""; \
	echo "Checking podman machine status..."; \
	if podman machine list 2>/dev/null | grep -q "Currently running"; then \
		echo "✓ podman machine: running"; \
	else \
		echo "⚠ podman machine: not running"; \
		echo "  Start with: podman machine start"; \
	fi; \
	echo ""; \
	echo "Checking container registry logins..."; \
	if podman login --get-login registry.redhat.io >/dev/null 2>&1; then \
		echo "✓ registry.redhat.io: logged in"; \
	else \
		echo "✗ registry.redhat.io: NOT LOGGED IN"; \
		echo "  Login: podman login registry.redhat.io"; \
		ERRORS=$$((ERRORS + 1)); \
	fi; \
	if podman login --get-login brew.registry.redhat.io >/dev/null 2>&1; then \
		echo "✓ brew.registry.redhat.io: logged in"; \
	else \
		echo "✗ brew.registry.redhat.io: NOT LOGGED IN"; \
		echo "  Login: podman login brew.registry.redhat.io"; \
		ERRORS=$$((ERRORS + 1)); \
	fi; \
	if podman login --get-login quay.io >/dev/null 2>&1; then \
		echo "✓ quay.io: logged in"; \
	else \
		echo "✗ quay.io: NOT LOGGED IN"; \
		echo "  Login: podman login quay.io"; \
		ERRORS=$$((ERRORS + 1)); \
	fi; \
	echo ""; \
	if [ $$ERRORS -gt 0 ]; then \
		echo "Preflight check failed with $$ERRORS error(s)"; \
		echo "Please resolve the issues above before continuing."; \
		exit 1; \
	else \
		echo "All preflight checks passed!"; \
	fi

.PHONY: harness/aap-dev/registry-login
## Login to required container registries
harness/aap-dev/registry-login:
	@echo "Logging into container registries..."
	@echo ""
	@echo "You will be prompted for credentials for each registry."
	@echo "Use your Red Hat credentials for registry.redhat.io and brew.registry.redhat.io"
	@echo ""
	@echo "=== registry.redhat.io ==="
	@podman login registry.redhat.io || true
	@echo ""
	@echo "=== brew.registry.redhat.io ==="
	@podman login brew.registry.redhat.io || true
	@echo ""
	@echo "=== quay.io ==="
	@podman login quay.io || true
	@echo ""
	@echo "Registry login complete. Run 'make harness/aap-dev/preflight' to verify."

.PHONY: harness/aap-dev/start
## Start the AAP development environment
harness/aap-dev/start:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed. Run 'make harness/aap-dev/install' first."; \
		exit 1; \
	fi
	@echo "Starting AAP Development Environment"
	@echo "====================================="
	@echo ""
	@echo "AAP Version: $(AAP_VERSION)"
	@echo "Directory: $(AAP_DEV_DIR)"
	@echo ""
	@echo "This will:"
	@echo "  1. Create a Kind Kubernetes cluster"
	@echo "  2. Deploy AAP using Skaffold"
	@echo "  3. Tail all pod logs (blocks terminal)"
	@echo ""
	@echo "Press Ctrl+C to stop and undeploy."
	@echo ""
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) AAP_CONTAINER_RUNTIME=$(AAP_CONTAINER_RUNTIME) make $(AAP_DEFAULT_MAKE_TARGET)
	@if [[ "$(AAP_INSTALL_LICENSE)" == "true" && "$(AAP_DEFAULT_MAKE_TARGET)" == "aap-deploy" ]]; then \
		cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) AAP_CONTAINER_RUNTIME=$(AAP_CONTAINER_RUNTIME) make aap-apply-license; \
	fi

.PHONY: harness/aap-dev/stop
## Stop the AAP development environment (clean kind cluster)
harness/aap-dev/stop:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@echo "Stopping AAP Development Environment..."
	@cd "$(AAP_DEV_DIR)" && make clean

.PHONY: harness/aap-dev/status
## Show AAP pod status
harness/aap-dev/status:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@cd "$(AAP_DEV_DIR)" && make aap-get-pods

.PHONY: harness/aap-dev/logs
## Tail AAP logs
harness/aap-dev/logs:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@cd "$(AAP_DEV_DIR)" && make aap-tail-logs

.PHONY: harness/aap-dev/admin-password
## Get the AAP admin password
harness/aap-dev/admin-password:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@cd "$(AAP_DEV_DIR)" && make admin-password

.PHONY: harness/aap-dev/apply-license
## Apply AAP license
harness/aap-dev/apply-license:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@echo "Applying AAP license..."
	@cd "$(AAP_DEV_DIR)" && make aap-apply-license

.PHONY: harness/aap-dev/backup
## Backup AAP PostgreSQL database
harness/aap-dev/backup:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@echo "Backing up AAP database..."
	@cd "$(AAP_DEV_DIR)" && make aap-backup

.PHONY: harness/aap-dev/restore
## Restore AAP database from backup
harness/aap-dev/restore:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@echo "Restoring AAP database..."
	@cd "$(AAP_DEV_DIR)" && make aap-restore

.PHONY: harness/aap-dev/versions
## List available AAP versions
harness/aap-dev/versions:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@echo "Available AAP Versions:"
	@cd "$(AAP_DEV_DIR)" && make list-versions

.PHONY: harness/aap-dev/clean
## Remove kind cluster and kubeconfig
harness/aap-dev/clean:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "AAP-Dev not installed, nothing to clean."; \
		exit 0; \
	fi
	@echo "Cleaning AAP-Dev kind cluster..."
	@cd "$(AAP_DEV_DIR)" && make clean

.PHONY: harness/aap-dev/clean-all
## Full removal of aap-dev resources
harness/aap-dev/clean-all:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "AAP-Dev not installed, nothing to clean."; \
		exit 0; \
	fi
	@echo "Performing full AAP-Dev cleanup..."
	@cd "$(AAP_DEV_DIR)" && make really-clean

.PHONY: harness/aap-dev/uninstall
## Remove the aap-dev directory entirely
harness/aap-dev/uninstall: harness/aap-dev/clean-all
	@echo "Removing AAP-Dev directory..."
	@rm -rf "$(AAP_DEV_DIR)"
	@echo "AAP-Dev uninstalled."

.PHONY: harness/aap-dev/update
## Update aap-dev to latest version
harness/aap-dev/update:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed. Run 'make harness/aap-dev/install' first."; \
		exit 1; \
	fi
	@echo "Updating AAP-Dev..."
	@cd "$(AAP_DEV_DIR)" && git pull origin $(AAP_DEV_BRANCH)
	@echo "AAP-Dev updated."

.PHONY: harness/aap-dev/url
## Show the AAP access URL for the current version
harness/aap-dev/url:
	@VERSION=$(AAP_VERSION); \
	PORT=$$(echo $$VERSION | tr -d '.' | sed 's/-.*//'); \
	echo "AAP $(AAP_VERSION) URL: http://localhost:449$${PORT}"
	@echo ""
	@echo "Default login: admin"
	@echo "Password: run 'make harness/aap-dev/admin-password'"

.PHONY: harness/aap-dev/events
## Show Kubernetes events across all namespaces
harness/aap-dev/events:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@cd "$(AAP_DEV_DIR)" && make aap-get-events

.PHONY: harness/aap-dev/shell
## Open a shell in the aap-dev directory
harness/aap-dev/shell:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed. Run 'make harness/aap-dev/install' first."; \
		exit 1; \
	fi
	@echo "Opening shell in $(AAP_DEV_DIR)..."
	@echo "Run 'exit' to return."
	@cd "$(AAP_DEV_DIR)" && exec $(SHELL)

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT TARGETS
# ═══════════════════════════════════════════════════════════════

.PHONY: harness/aap-dev/is-running
## Check if AAP is currently running (silent, for scripting)
harness/aap-dev/is-running:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		exit 1; \
	fi
	@cd "$(AAP_DEV_DIR)" && \
		if [ -f "bin/kubectl" ]; then \
			KUBECONFIG=$$(pwd)/tmp/kubeconfig-$(AAP_VERSION) ./bin/kubectl get pods -n myaap >/dev/null 2>&1 || exit 1; \
		else \
			exit 1; \
		fi

.PHONY: harness/aap-dev/deploy
## Deploy AAP without blocking (skaffold deploy)
harness/aap-dev/deploy:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed. Run 'make harness/aap-dev/install' first."; \
		exit 1; \
	fi
	@echo "Deploying AAP $(AAP_VERSION)..."
	@echo ""
	@echo "This will:"
	@echo "  1. Create Kind cluster if needed"
	@echo "  2. Build and deploy AAP images"
	@echo "  3. Return when deployment is complete"
	@echo ""
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make skaffold-deploy
	@echo ""
	@echo "Deployment complete. Waiting for API to be ready..."
	@$(MAKE) harness/aap-dev/wait-up

.PHONY: harness/aap-dev/wait-up
## Wait for AAP API to become available
harness/aap-dev/wait-up:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; \
		exit 1; \
	fi
	@echo "Waiting for AAP API to become available..."
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make aap-wait-up
	@echo ""
	@echo "AAP is ready!"
	@$(MAKE) harness/aap-dev/url

.PHONY: harness/aap-dev/ensure-running
## Ensure AAP is deployed and ready (deploys if not running)
harness/aap-dev/ensure-running:
	@if [ "$(AAP_SKIP_DEPLOY_CHECK)" = "true" ]; then \
		echo "Skipping deployment check (AAP_SKIP_DEPLOY_CHECK=true)"; \
		exit 0; \
	fi
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "AAP-Dev not installed. Installing..."; \
		$(MAKE) harness/aap-dev/install; \
	fi
	@echo "Checking if AAP is running..."
	@if $(MAKE) harness/aap-dev/is-running 2>/dev/null; then \
		echo "✓ AAP is already running"; \
		$(MAKE) harness/aap-dev/url; \
	else \
		echo "AAP is not running. Starting deployment..."; \
		echo ""; \
		echo "NOTE: This will deploy AAP in the background."; \
		echo "      For interactive mode with logs, use 'make harness/aap-dev/start'"; \
		echo ""; \
		$(MAKE) harness/aap-dev/deploy; \
	fi

# ═══════════════════════════════════════════════════════════════
# TEST TARGETS (Auto-deploy AAP before running tests)
# ═══════════════════════════════════════════════════════════════

.PHONY: harness/aap-dev/test/init
## Initialize the ATF test suite
harness/aap-dev/test/init: harness/aap-dev/ensure-running
	@echo ""
	@echo "Initializing ATF Test Suite"
	@echo "==========================="
	@cd "$(AAP_DEV_DIR)" && make test-atf-init

.PHONY: harness/aap-dev/test
## Run all ATF core tests (ensures AAP is deployed first)
harness/aap-dev/test: harness/aap-dev/ensure-running
	@echo ""
	@echo "Running ATF Core Tests"
	@echo "======================"
	@echo "AAP Version: $(AAP_VERSION)"
	@echo ""
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run

.PHONY: harness/aap-dev/test/controller
## Run controller component tests (ensures AAP is deployed first)
harness/aap-dev/test/controller: harness/aap-dev/ensure-running
	@echo ""
	@echo "Running Controller Tests"
	@echo "========================"
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-controller

.PHONY: harness/aap-dev/test/eda
## Run EDA component tests (ensures AAP is deployed first)
harness/aap-dev/test/eda: harness/aap-dev/ensure-running
	@echo ""
	@echo "Running EDA Tests"
	@echo "================="
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-eda

.PHONY: harness/aap-dev/test/hub
## Run hub component tests (ensures AAP is deployed first)
harness/aap-dev/test/hub: harness/aap-dev/ensure-running
	@echo ""
	@echo "Running Hub Tests"
	@echo "================="
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-hub

.PHONY: harness/aap-dev/test/portal
## Run ansible-portal component tests (ensures AAP is deployed first)
harness/aap-dev/test/portal: harness/aap-dev/ensure-running
	@echo ""
	@echo "Running Portal Tests"
	@echo "===================="
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-portal

.PHONY: harness/aap-dev/test/platform-services
## Run platform-services component tests (ensures AAP is deployed first)
harness/aap-dev/test/platform-services: harness/aap-dev/ensure-running
	@echo ""
	@echo "Running Platform Services Tests"
	@echo "==============================="
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-ps

.PHONY: harness/aap-dev/test/emerging-services
## Run emerging-services tests (metrics service/utility) (ensures AAP is deployed first)
harness/aap-dev/test/emerging-services: harness/aap-dev/ensure-running
	@echo ""
	@echo "Running Emerging Services Tests"
	@echo "==============================="
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-es

.PHONY: harness/aap-dev/test/all
## Run all component test suites (ensures AAP is deployed first)
harness/aap-dev/test/all: harness/aap-dev/ensure-running
	@echo ""
	@echo "Running All Component Tests"
	@echo "==========================="
	@echo "AAP Version: $(AAP_VERSION)"
	@echo ""
	@echo "This will run tests for: controller, eda, hub, portal, platform-services, emerging-services"
	@echo ""
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-controller
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-eda
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-hub
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-portal
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-ps
	@cd "$(AAP_DEV_DIR)" && AAP_VERSION=$(AAP_VERSION) make test-atf-run-es
	@echo ""
	@echo "All tests complete!"

# ═══════════════════════════════════════════════════════════════
# SOURCE CONFIGURATION TARGETS
# ═══════════════════════════════════════════════════════════════

.PHONY: harness/aap-dev/configure-sources
## Configure custom sources interactively
harness/aap-dev/configure-sources:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; exit 1; \
	fi
	@cd "$(AAP_DEV_DIR)" && make configure-sources

.PHONY: harness/aap-dev/configure-sources-auto
## Configure sources from answers file (non-interactive)
## Usage: make harness/aap-dev/configure-sources-auto ANSWERS_FILE=path/to/answers.json
harness/aap-dev/configure-sources-auto:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; exit 1; \
	fi
	@if [ -z "$(ANSWERS_FILE)" ]; then \
		echo "Error: ANSWERS_FILE is required."; exit 1; \
	fi
	@cd "$(AAP_DEV_DIR)" && \
		CONFIGURATION_ANSWERS_FILE="$(ANSWERS_FILE)" \
		CONFIGURATION_ERROR_ON_NO_ANSWER=true \
		make configure-sources

.PHONY: harness/aap-dev/show-sources
## Show currently configured sources
harness/aap-dev/show-sources:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; exit 1; \
	fi
	@SOURCES_FILE="$(AAP_DEV_DIR)/src/$(AAP_VERSION)/sources.yaml"; \
	if [ -f "$$SOURCES_FILE" ]; then \
		echo "Current sources ($(AAP_VERSION)):"; \
		cat "$$SOURCES_FILE"; \
	else \
		echo "No custom sources configured (using default nightly images)"; \
	fi

.PHONY: harness/aap-dev/reset-sources
## Reset sources to defaults (remove src/ overrides)
harness/aap-dev/reset-sources:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; exit 1; \
	fi
	@echo "Resetting sources to defaults..."
	@rm -rf "$(AAP_DEV_DIR)/src/$(AAP_VERSION)"
	@echo "Sources reset. Next deployment will use default nightly images."

# ═══════════════════════════════════════════════════════════════
# DATA SEEDING TARGETS
# ═══════════════════════════════════════════════════════════════

.PHONY: harness/aap-dev/seed
## Seed data into AAP instance using default playbook
harness/aap-dev/seed: harness/aap-dev/ensure-running
	@ADMIN_PW=$$(cd "$(AAP_DEV_DIR)" && make admin-password 2>&1 | tail -1); \
	VERSION_PORT=$$(echo $(AAP_VERSION) | tr -d '.' | sed 's/-.*//'); \
	cd "$(AAP_DEV_DIR)" && ansible-playbook \
		playbooks/data-seeding/aap-dev-data-seeding.yaml \
		-e "aap_host=http://localhost:449$${VERSION_PORT}" \
		-e "aap_admin_password=$${ADMIN_PW}"

.PHONY: harness/aap-dev/seed-custom
## Seed data using a custom playbook
## Usage: make harness/aap-dev/seed-custom SEED_PLAYBOOK=path/to/playbook.yaml
harness/aap-dev/seed-custom: harness/aap-dev/ensure-running
	@if [ -z "$(SEED_PLAYBOOK)" ]; then \
		echo "Error: SEED_PLAYBOOK is required."; exit 1; \
	fi
	@ADMIN_PW=$$(cd "$(AAP_DEV_DIR)" && make admin-password 2>&1 | tail -1); \
	VERSION_PORT=$$(echo $(AAP_VERSION) | tr -d '.' | sed 's/-.*//'); \
	cd "$(AAP_DEV_DIR)" && ansible-playbook \
		"$(SEED_PLAYBOOK)" \
		-e "aap_host=http://localhost:449$${VERSION_PORT}" \
		-e "aap_admin_password=$${ADMIN_PW}"

# ═══════════════════════════════════════════════════════════════
# CONTENT REGENERATION TARGETS
# ═══════════════════════════════════════════════════════════════

.PHONY: harness/aap-dev/regenerate-containerfiles
## Regenerate Containerfiles from upstream/nightly definitions
harness/aap-dev/regenerate-containerfiles:
	@if [ ! -d "$(AAP_DEV_DIR)" ]; then \
		echo "Error: AAP-Dev not installed."; exit 1; \
	fi
	@echo "Regenerating Containerfiles..."
	@cd "$(AAP_DEV_DIR)" && make regenerate-containerfiles

.PHONY: harness/aap-dev/regenerate-k8s-manifests
## Extract K8s manifests from running AAP instance
harness/aap-dev/regenerate-k8s-manifests: harness/aap-dev/ensure-running
	@echo "Extracting K8s manifests from running instance..."
	@cd "$(AAP_DEV_DIR)" && \
		KUBECONFIG="$(AAP_DEV_DIR)/tmp/kubeconfig-$(AAP_VERSION)" \
		make regenerate-k8s-manifests

# ═══════════════════════════════════════════════════════════════
# OBSERVABILITY TARGETS
# ═══════════════════════════════════════════════════════════════

.PHONY: harness/aap-dev/metrics
## Show CPU/memory usage per pod
harness/aap-dev/metrics: harness/aap-dev/ensure-running
	@cd "$(AAP_DEV_DIR)" && make metrics-server-install 2>/dev/null || true
	@KUBECONFIG="$(AAP_DEV_DIR)/tmp/kubeconfig-$(AAP_VERSION)" \
		"$(AAP_DEV_DIR)/bin/kubectl" top pod --all-namespaces

.PHONY: harness/aap-dev/metrics-node
## Show CPU/memory usage per node
harness/aap-dev/metrics-node: harness/aap-dev/ensure-running
	@cd "$(AAP_DEV_DIR)" && make metrics-server-install 2>/dev/null || true
	@KUBECONFIG="$(AAP_DEV_DIR)/tmp/kubeconfig-$(AAP_VERSION)" \
		"$(AAP_DEV_DIR)/bin/kubectl" top node

.PHONY: harness/aap-dev/observability
## Install Prometheus + Grafana stack and start port-forward
harness/aap-dev/observability: harness/aap-dev/ensure-running
	@cd "$(AAP_DEV_DIR)" && make kube-prometheus-stack-install
	@echo ""
	@echo "Starting Grafana port-forward (http://localhost:13000)..."
	@echo "Credentials: admin / prom-operator"
	@cd "$(AAP_DEV_DIR)" && make kube-prometheus-stack-port-forward
