# Harness Test Generation and Discovery Module

.PHONY: harness/suggest-tests harness/find-tests harness/test-coverage harness/commit-func-tests

## Generate test cases from Jira acceptance criteria and code analysis
harness/suggest-tests: harness/context
	@echo "Generating tests from acceptance criteria..."
	@if [ "$(HARNESS_DRY_RUN)" = "true" ]; then \
		$(HARNESS_PATH)/modules/harness/scripts/prompt-render.sh test-generation; \
		echo ""; \
		echo "[Dry run - prompt shown above, agent not called]"; \
	else \
		$(HARNESS_PATH)/modules/harness/scripts/paude-session.sh run test-generation $(HARNESS_PROVIDER_TESTS); \
		$(HARNESS_PATH)/modules/harness/scripts/results-format.sh test-generation; \
	fi

## Discover existing tests that cover modified code
harness/find-tests: harness/context/code
	@echo "Discovering existing tests..."
	@$(HARNESS_PATH)/modules/harness/scripts/test-discovery.sh
	@if [ "$(HARNESS_PROVIDER_DISCOVERY)" != "local" ]; then \
		echo "Running semantic analysis..."; \
		$(HARNESS_PATH)/modules/harness/scripts/paude-session.sh run test-discovery $(HARNESS_PROVIDER_DISCOVERY); \
	fi
	@$(HARNESS_PATH)/modules/harness/scripts/results-format.sh test-discovery

## Analyze test coverage for modified code
harness/test-coverage: harness/context/code
	@echo "Analyzing test coverage..."
	@$(HARNESS_PATH)/modules/harness/scripts/test-coverage.sh

## Commit generated functional tests to the functional test repo and open a PR
## Requires: HARNESS_FUNC_TEST_REPO configured, harness/suggest-tests run first
harness/commit-func-tests:
	@echo "Committing functional tests to $(HARNESS_FUNC_TEST_REPO)..."
	@$(HARNESS_PATH)/modules/harness/scripts/func-test-pr.sh
