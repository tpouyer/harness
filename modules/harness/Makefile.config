# Harness Configuration Management

.PHONY: harness/config harness/config/validate harness/config/show

## Display resolved configuration and validate credentials
harness/config: harness/config/show harness/config/validate

## Show resolved configuration (without sensitive values)
harness/config/show:
	@echo "Harness Configuration"
	@echo "====================="
	@echo ""
	@echo "Jira:"
	@echo "  Base URL:      $(HARNESS_JIRA_BASE_URL)"
	@echo "  Project:       $(HARNESS_JIRA_PROJECT)"
	@echo "  Email:         $(if $(HARNESS_JIRA_EMAIL),$(HARNESS_JIRA_EMAIL),<not set>)"
	@echo "  API Token:     $(if $(HARNESS_JIRA_API_TOKEN),****,<not set>)"
	@echo "  Branch Pattern: $(HARNESS_BRANCH_PATTERN)"
	@echo ""
	@echo "AI Provider:"
	@echo "  Provider:      $(HARNESS_AI_PROVIDER)"
	@echo "  Model:         $(HARNESS_AI_MODEL)"
	@echo "  API Key:       $(if $(HARNESS_AI_API_KEY),****,<not set>)"
	@echo "  Fallback:      $(HARNESS_AI_FALLBACK)"
	@echo ""
	@echo "Agent Stack:"
	@echo "  OpenCode:      $(HARNESS_OPENCODE_BIN) $(HARNESS_OPENCODE_VERSION)"
	@echo "  Beads:         $(HARNESS_BEADS_BIN)"
	@echo "  Swarm Workers: $(HARNESS_SWARM_WORKERS)"
	@echo "  AAP-Dev Dir:   $(AAP_DEV_DIR)"
	@echo ""
	@echo "Output:"
	@echo "  Format:        $(HARNESS_OUTPUT_FORMAT)"
	@echo "  Dry Run:       $(HARNESS_DRY_RUN)"
	@echo "  Cache TTL:     $(HARNESS_CACHE_TTL)s"

## Validate credentials against services
harness/config/validate:
	@echo ""
	@echo "Validating credentials..."
	@$(HARNESS_PATH)/modules/harness/scripts/validate-config.sh
