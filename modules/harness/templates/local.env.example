# Harness Local Configuration
# Copy this file to .harness.local.env and add your credentials
# This file should be gitignored - never commit credentials!

# ═══════════════════════════════════════════════════════════════
# JIRA CREDENTIALS
# ═══════════════════════════════════════════════════════════════

HARNESS_JIRA_BASE_URL=https://issues.redhat.com
HARNESS_JIRA_API_TOKEN=your-jira-pat

# Auth type: "bearer" for Jira Server/DC (PAT), "basic" for Jira Cloud (email+token)
# When set to "auto" (default), bearer is used if HARNESS_JIRA_EMAIL is empty.
HARNESS_JIRA_AUTH_TYPE=bearer

# For Jira Cloud only (not needed for Red Hat Jira):
# HARNESS_JIRA_EMAIL=your.email@company.com

# To generate a Jira Personal Access Token (Red Hat Jira):
# 1. Go to https://issues.redhat.com/secure/ViewProfile.jspa?selectedTab=com.atlassian.pats.pats-plugin:jira-user-personal-access-tokens
# 2. Click "Create token"
# 3. Copy the token here
#
# For Jira Cloud:
# 1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Click "Create API token"
# 3. Set HARNESS_JIRA_EMAIL and paste the token above

# ═══════════════════════════════════════════════════════════════
# GOOGLE CLOUD / VERTEX AI (Claude via Vertex)
# ═══════════════════════════════════════════════════════════════

# Authenticate first (one-time):
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <GCP_PROJECT_ID>

# Google Cloud project ID with Vertex AI + Claude enabled
GCP_PROJECT_ID=your-gcp-project-id

# Region (default: us-east5)
# GCP_REGION=us-east5

# Quota project (defaults to GCP_PROJECT_ID if not set)
# GCP_QUOTA_PROJECT=your-quota-project

# ═══════════════════════════════════════════════════════════════
# GITHUB CREDENTIALS (For Handbook Document Access)
# ═══════════════════════════════════════════════════════════════

# GitHub Personal Access Token (for private handbook repos)
# Required scopes: repo (for private) or public_repo (for public)
# Get token from: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_...

# ═══════════════════════════════════════════════════════════════
# AAP DEVELOPMENT (Optional)
# ═══════════════════════════════════════════════════════════════

# Container registry credentials for AAP images
# AAP_REGISTRY_URL=registry.redhat.io

# Create your service account here: https://access.redhat.com/terms-based-registry/
# Click "New Service Account" and provide a Name and Description
# Copy the username and token from the new service account
# set AAP_REGISTRY_USER=$(copied service account username)
# set AAP_REGISTRY_PASSWORD=$(copied service account token)
# AAP_REGISTRY_USER=your-username
# AAP_REGISTRY_PASSWORD=your-password

# AAP_VERSION=2.6-next
# AAP_CONTAINER_RUNTIME=podman
# AAP_DEV_DIR=$(HOME)/aap-dev

# Use "aap-deploy" for non-blocking aap deployment
# AAP_DEPLOY_MAKE_TARGET=aap

# Kubernetes config override (default: ~/.kube/config)
# KUBECONFIG=/path/to/custom/kubeconfig

# ═══════════════════════════════════════════════════════════════
# PAUDE CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════

# Container backend: podman or openshift
HARNESS_PAUDE_BACKEND=podman

# Network allowlist for agent containers
HARNESS_PAUDE_ALLOWED_DOMAINS=api.anthropic.com,api.openai.com,*.googleapis.com,*.atlassian.net

# Container registry for harness agent images
# HARNESS_CONTAINER_REGISTRY=ghcr.io/ansible-automation-platform

# ═══════════════════════════════════════════════════════════════
# PREFERENCES (Optional)
# ═══════════════════════════════════════════════════════════════

# Cache TTL in seconds (default: 1800 = 30 minutes)
# HARNESS_CACHE_TTL=1800

# Context limits
# HARNESS_MAX_CONTEXT_TOKENS=100000
# HARNESS_MAX_FILES=50
