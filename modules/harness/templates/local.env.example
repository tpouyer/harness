# Harness Local Configuration
# Copy this file to .harness.local.env and add your credentials
# This file should be gitignored - never commit credentials!

# ═══════════════════════════════════════════════════════════════
# JIRA CREDENTIALS
# ═══════════════════════════════════════════════════════════════

HARNESS_JIRA_BASE_URL=https://your-company.atlassian.net
HARNESS_JIRA_EMAIL=your.email@company.com
HARNESS_JIRA_API_TOKEN=your-jira-api-token

# To generate a Jira API token:
# 1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Click "Create API token"
# 3. Copy the token here

# ═══════════════════════════════════════════════════════════════
# AI PROVIDER CREDENTIALS
# ═══════════════════════════════════════════════════════════════

# Choose your provider and add the corresponding API key
HARNESS_AI_PROVIDER=claude
HARNESS_AI_API_KEY=your-api-key-here

# Claude (Anthropic)
# Get API key from: https://console.anthropic.com/settings/keys
# HARNESS_AI_API_KEY=sk-ant-...

# OpenAI
# Get API key from: https://platform.openai.com/api-keys
# HARNESS_AI_API_KEY=sk-...

# Google Vertex AI
# Use service account: export GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Local (Ollama) - no API key needed
# HARNESS_AI_PROVIDER=local
# HARNESS_AI_MODEL=llama3.2

# ═══════════════════════════════════════════════════════════════
# PAUDE CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════

# Container backend: podman or openshift
HARNESS_PAUDE_BACKEND=podman

# Network allowlist for agent containers
HARNESS_PAUDE_ALLOWED_DOMAINS=api.anthropic.com,api.openai.com,*.atlassian.net

# Container registry for harness agent images
# HARNESS_CONTAINER_REGISTRY=ghcr.io/your-org

# ═══════════════════════════════════════════════════════════════
# PREFERENCES (Optional)
# ═══════════════════════════════════════════════════════════════

# Cache TTL in seconds (default: 1800 = 30 minutes)
# HARNESS_CACHE_TTL=1800

# Context limits
# HARNESS_MAX_CONTEXT_TOKENS=100000
# HARNESS_MAX_FILES=50
