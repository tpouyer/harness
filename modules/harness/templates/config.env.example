# Harness Project Configuration
# This file is committed to git and contains project-wide settings

# Jira Configuration
HARNESS_JIRA_PROJECT=MYPROJ
HARNESS_BRANCH_PATTERN=([A-Z]+-[0-9]+)

# AI Provider (claude, openai, local, vertex)
HARNESS_AI_PROVIDER=claude

# Model selection (provider-specific)
# Claude: claude-sonnet-4-5-20250514, claude-opus-4-20250514
# OpenAI: gpt-4-turbo-preview, gpt-4o
# Local: llama3.2, codellama
# Vertex: gemini-1.5-pro
HARNESS_AI_MODEL=claude-sonnet-4-5-20250514

# Per-capability provider routing (optional)
# HARNESS_PROVIDER_INTENT=claude
# HARNESS_PROVIDER_TESTS=claude
# HARNESS_PROVIDER_ASSIST=openai
# HARNESS_PROVIDER_DISCOVERY=local

# Language/Framework (auto-detected if not set)
# HARNESS_LANGUAGE=python
# HARNESS_TEST_FRAMEWORK=pytest

# Output format (markdown, json)
HARNESS_OUTPUT_FORMAT=markdown

# Functional Test Repository
# Functional tests require aap-dev to run and live in a separate repo.
# Unit tests discovered/generated locally stay in this repo.
#
# Path to the cloned functional test repo (relative or absolute)
# HARNESS_FUNC_TEST_REPO=../my-functional-tests
#
# Branch prefix used when creating feature branches in the functional test repo
# HARNESS_FUNC_TEST_BRANCH_PREFIX=harness/
#
# Remote to push functional test branches to (for PR creation)
# HARNESS_FUNC_TEST_REMOTE=origin
#
# Default branch in the functional test repo (PR target)
# HARNESS_FUNC_TEST_DEFAULT_BRANCH=main
